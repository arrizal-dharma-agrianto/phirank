# DATABASE
DATABASE_URL=YOUR_DATABASE_URL
DATABASE_LOG=true

# AUTH
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="super-secret"
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# OBJECT STORAGE
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=
S3_FORCE_PATH_STYLE=
NEXT_PUBLIC_S3_PUBLIC_URL=
S3_UPLOAD_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# DOCKER
MINIO_VERSION=latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# DEVTOOLS
NEXT_PUBLIC_TANSTACK_QUERY_DEVTOOLS=true

# GROQ
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# DATAFORSEO
# Options: dataforseo, crawlee
DATA_AUDIT_CRAWLER_PROVIDER=dataforseo
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
BACKLINK_PROFILE=true

# CRAWLEE
CRAWLEE_MAX_CONCURRENCY=4
CRAWLEE_REQUEST_TIMEOUT_SECS=20

# SMTP
MAIL_DRIVER=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=yourpassword
MAIL_FROM=Boilerplate SaaS <example@gmail.com>
