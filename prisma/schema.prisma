// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum WebAuditStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  passwordHash String?    @map("password_hash")
  status       UserStatus @default(ACTIVE)

  accounts    Account[]
  sessions    Session[]
  memberships TenantMember[]
  webAudits   WebAudit[]
  websites    Website[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String @id @default(cuid())
  userId            String @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String? @db.Text
  access_token  String? @db.Text
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String? @db.Text
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tenant {
  id     String       @id @default(cuid())
  name   String
  slug   String       @unique
  status TenantStatus @default(ACTIVE)

  members     TenantMember[]
  settings    TenantSettings?
  invitations TenantInvitation[]
  roles       Role[]

  subscriptions                Subscription[]
  invoices                     Invoice[]
  webAudits                    WebAudit[]
  contentGeneratorIntegrations ContentGeneratorIntegration[]
  contentGeneratorIndexNow     ContentGeneratorIndexNow?
  contentGeneratorDrafts       ContentGeneratorDraft[]
  websites                     Website[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model ContentGeneratorIntegration {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  webhookUrl    String @map("webhook_url")
  webhookSecret String @map("webhook_secret")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, webhookUrl])
  @@index([tenantId])
  @@index([webhookUrl])
  @@map("content_generator_integrations")
}

model ContentGeneratorIndexNow {
  id       String @id @default(cuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key              String
  keyLocation      String  @map("key_location")
  status           String
  lastVerifiedAt   DateTime? @map("last_verified_at")
  lastSubmittedUrl String?   @map("last_submitted_url")
  lastError        String?   @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("content_generator_indexnow")
}

model ContentGeneratorDraft {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  title  String
  content String
  model   String?
  source  Json
  status  String

  metaTitle          String? @map("meta_title")
  titleOptions       Json    @default("[]") @map("title_options")
  metaDescription    String? @map("meta_description")
  descriptionOptions Json    @default("[]") @map("description_options")
  slug               String?
  slugOptions        Json    @default("[]") @map("slug_options")
  strategySummary    String? @map("strategy_summary")
  mainContent        String? @map("main_content")
  internalLinks      Json    @default("[]") @map("internal_links")
  imageAltTexts      Json    @default("[]") @map("image_alt_texts")
  faq                Json    @default("[]")
  seoNotes           Json    @default("[]") @map("seo_notes")
  sections           Json    @default("{}")

  publishDeliveryId String?   @map("publish_delivery_id")
  publishStatusCode Int?      @map("publish_status_code")
  publishError      String?   @map("publish_error")
  publishedAt       DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("content_generator_drafts")
}

model TenantSettings {
  id       String @id @default(cuid())
  tenantId String @unique @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  timezone String @default("Asia/Jakarta")
  locale   String @default("en")
  currency String @default("USD")
  showSetupProgress Boolean @default(true) @map("show_setup_progress")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

model TenantMember {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  tenantId String @map("tenant_id")
  roleId   String @map("role_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id])

  invitedById String?   @map("invited_by_id")
  invitedAt   DateTime? @map("invited_at")
  joinedAt    DateTime? @map("joined_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@map("tenant_members")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  group       String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model Role {
  id       String  @id @default(cuid())
  tenantId String? @map("tenant_id")
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?

  isSystem  Boolean @default(false) @map("is_system")
  isDefault Boolean @default(false) @map("is_default")

  members     TenantMember[]
  invitations TenantInvitation[]
  permissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model TenantInvitation {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])

  email       String
  status      InvitationStatus @default(PENDING)
  token       String           @unique
  invitedById String?          @map("invited_by_id")
  expiresAt   DateTime         @map("expires_at")
  acceptedAt  DateTime?        @map("accepted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([roleId])
  @@index([email])
  @@map("tenant_invitations")
}

model Plan {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  priceCents  Int             @map("price_cents")
  currency    String          @default("USD")
  interval    BillingInterval @default(MONTHLY)
  isActive    Boolean         @default(true) @map("is_active")

  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model Subscription {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  planId   String @map("plan_id")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  trialStart         DateTime?          @map("trial_start")
  trialEnd           DateTime?          @map("trial_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt         DateTime?          @map("canceled_at")

  provider               String?
  providerCustomerId     String? @map("provider_customer_id")
  providerSubscriptionId String? @unique @map("provider_subscription_id")

  invoices Invoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id             String  @id @default(cuid())
  tenantId       String  @map("tenant_id")
  subscriptionId String? @map("subscription_id")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  invoiceNumber     String?       @unique @map("invoice_number")
  status            InvoiceStatus @default(DRAFT)
  amountCents       Int           @map("amount_cents")
  currency          String        @default("USD")
  dueDate           DateTime?     @map("due_date")
  paidAt            DateTime?     @map("paid_at")
  providerInvoiceId String?       @unique @map("provider_invoice_id")
  hostedInvoiceUrl  String?       @map("hosted_invoice_url")
  invoicePdfUrl     String?       @map("invoice_pdf_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  userId    String?  @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

model WebAudit {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url          String
  status       WebAuditStatus @default(COMPLETED)
  progress     Int            @default(100)
  currentStep  String?        @map("current_step")
  overallScore Int            @map("overall_score")
  categories   Json
  findings     Json
  errorMessage String?        @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("web_audits")
}

model Website {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name              String
  domain            String
  startUrl          String    @map("start_url")
  industry          String?
  targetCountry     String    @default("Indonesia") @map("target_country")
  targetLanguage    String    @default("id") @map("target_language")
  maxCrawlPages     Int       @default(100) @map("max_crawl_pages")
  crawlStatus       String    @default("pending") @map("crawl_status")
  currentCrawlJobId String?   @map("current_crawl_job_id")
  lastCrawledAt     DateTime? @map("last_crawled_at")

  crawlJobs      CrawlJob[]
  crawlPages     CrawlPage[]
  crawlLinks     CrawlLink[]
  crawlSummaries CrawlSummary[]
  backlinkProfiles BacklinkProfile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, domain])
  @@index([tenantId])
  @@index([userId])
  @@index([crawlStatus])
  @@map("websites")
}

model BacklinkProfile {
  id        String  @id @default(cuid())
  websiteId String  @map("website_id")
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  provider           String @default("dataforseo")
  target             String
  totalBacklinks     Int    @default(0) @map("total_backlinks")
  referringDomains   Int    @default(0) @map("referring_domains")
  referringMainDomains Int  @default(0) @map("referring_main_domains")
  dofollowBacklinks  Int    @default(0) @map("dofollow_backlinks")
  nofollowBacklinks  Int    @default(0) @map("nofollow_backlinks")
  rawResponse        Json?  @map("raw_response")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([websiteId])
  @@index([createdAt])
  @@map("backlink_profiles")
}

model CrawlJob {
  id        String  @id @default(cuid())
  websiteId String  @map("website_id")
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  provider       String    @default("dataforseo")
  providerTaskId String?   @map("provider_task_id")
  status         String    @default("pending")
  maxCrawlPages  Int       @default(100) @map("max_crawl_pages")
  startedAt      DateTime? @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  errorMessage   String?   @map("error_message")
  rawRequest     Json?     @map("raw_request")
  rawResponse    Json?     @map("raw_response")

  crawlPages     CrawlPage[]
  crawlLinks     CrawlLink[]
  crawlSummaries CrawlSummary[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([websiteId])
  @@index([providerTaskId])
  @@index([status])
  @@map("crawl_jobs")
}

model CrawlPage {
  id         String   @id @default(cuid())
  websiteId  String   @map("website_id")
  crawlJobId String   @map("crawl_job_id")
  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  crawlJob   CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  url                   String
  normalizedUrl         String?  @map("normalized_url")
  statusCode            Int?     @map("status_code")
  title                 String?
  metaDescription       String?  @map("meta_description")
  h1                    String?
  wordCount             Int?     @map("word_count")
  internalLinksCount    Int?     @map("internal_links_count")
  externalLinksCount    Int?     @map("external_links_count")
  imagesCount           Int?     @map("images_count")
  imagesMissingAltCount Int?     @map("images_missing_alt_count")
  isIndexable           Boolean? @map("is_indexable")
  isMobileFriendly      Boolean? @map("is_mobile_friendly")
  canonicalUrl          String?  @map("canonical_url")
  headingStructure      Json     @default("[]") @map("heading_structure")
  rawMetrics            Json?    @map("raw_metrics")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([crawlJobId, url])
  @@index([websiteId])
  @@index([crawlJobId])
  @@map("crawl_pages")
}

model CrawlLink {
  id         String   @id @default(cuid())
  websiteId  String   @map("website_id")
  crawlJobId String   @map("crawl_job_id")
  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  crawlJob   CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  sourceUrl        String  @map("source_url")
  targetUrl        String  @map("target_url")
  anchorText       String? @map("anchor_text")
  isInternal       Boolean @default(false) @map("is_internal")
  isExternal       Boolean @default(false) @map("is_external")
  isBroken         Boolean @default(false) @map("is_broken")
  statusCode       Int?    @map("status_code")
  linkType         String? @map("link_type")
  finalUrl         String? @map("final_url")
  redirectChain    Json?   @map("redirect_chain")
  redirectHopCount Int     @default(0) @map("redirect_hop_count")
  rawData          Json?   @map("raw_data")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([websiteId])
  @@index([crawlJobId])
  @@index([isBroken])
  @@index([redirectHopCount])
  @@map("crawl_links")
}

model CrawlSummary {
  id         String   @id @default(cuid())
  websiteId  String   @map("website_id")
  crawlJobId String   @map("crawl_job_id")
  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  crawlJob   CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  totalPages                  Int   @default(0) @map("total_pages")
  crawledPages                Int   @default(0) @map("crawled_pages")
  brokenLinksCount            Int   @default(0) @map("broken_links_count")
  redirectsCount              Int   @default(0) @map("redirects_count")
  missingTitleCount           Int   @default(0) @map("missing_title_count")
  missingMetaDescriptionCount Int   @default(0) @map("missing_meta_description_count")
  missingH1Count              Int   @default(0) @map("missing_h1_count")
  missingAltTextCount         Int   @default(0) @map("missing_alt_text_count")
  rawSummary                  Json? @map("raw_summary")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([crawlJobId])
  @@index([websiteId])
  @@map("crawl_summaries")
}
